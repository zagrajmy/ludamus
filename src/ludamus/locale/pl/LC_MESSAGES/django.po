#: src/ludamus/templates/panel/time-slots.html:120
msgid "No slots"
msgstr "Brak przedziałów czasowych"

#: src/ludamus/templates/panel/time-slots.html:124
msgid "Event ends at"
msgstr "Wydarzenie kończy się"

#: src/ludamus/templates/panel/time-slots.html:143
