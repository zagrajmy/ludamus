{
  "compilerOptions": {
    "strict": true,
    "target": "es2024",
    "module": "es2022",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "types": [],
    "lib": [
      "es2024",
      "DOM",
      "DOM.Iterable"
    ],
    "outDir": "../../../../../static/js",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
