#!/usr/bin/env bash
# Inner half of `mise dev` once portless has wrapped the process.
# Reads PORTLESS_URL, normalizes ROOT_DOMAIN/ALLOWED_HOSTS, syncs Site(SITE_ID),
# and exec's honcho. Pulled out of scripts/dev so the LAN and non-LAN
# branches can share it without each carrying a 14-line `bash -lc` heredoc.

set -euo pipefail

if [ -z "${PORTLESS_URL:-}" ]; then
  echo "[dev] PORTLESS_URL missing" >&2
  exit 1
fi

root_domain="${PORTLESS_URL#http://}"
root_domain="${root_domain#https://}"
root_domain="${root_domain%/}"

export ROOT_DOMAIN="$root_domain"
export ALLOWED_HOSTS=".localhost,127.0.0.1,localhost,.local"

printf '[dev] auth0=%s root=%s app_port=%s\n' \
  "${AUTH0_DOMAIN:-?}" "$ROOT_DOMAIN" "${PORT:-?}" >&2

python - <<'PY'
import os, sys

os.environ.setdefault("DJANGO_SETTINGS_MODULE", "ludamus.edges.settings")
import django

django.setup()
from django.conf import settings
from django.contrib.sites.models import Site
from django.core.management import call_command

call_command("migrate", interactive=False)

root_domain = os.environ["ROOT_DOMAIN"]
site_id = settings.SITE_ID
existing = Site.objects.filter(id=site_id).values_list("domain", flat=True).first()
if existing != root_domain:
    print(
        f"[dev] Site(id={site_id}).domain: {existing!r} -> {root_domain!r}",
        file=sys.stderr,
    )
Site.objects.update_or_create(
    id=site_id, defaults={"domain": root_domain, "name": root_domain}
)
PY

exec honcho start -e /dev/null -f Procfile.dev
