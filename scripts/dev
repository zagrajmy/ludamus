#!/usr/bin/env bash

set -euo pipefail

port=""
use_portless="1"
use_lan="0"
do_trust="0"

ensure_simulacrum_certs() {
  local dest="$HOME/.simulacrum/certs"
  if [ -f "$dest/localhost.pem" ] && [ -f "$dest/localhost-key.pem" ]; then
    return 0
  fi
  local src_pem="$HOME/.portless/server.pem"
  local src_key="$HOME/.portless/server-key.pem"
  if [ ! -f "$src_pem" ] || [ ! -f "$src_key" ]; then
    echo "[dev] no portless certs at ~/.portless; auth0-simulator disabled" >&2
    return 1
  fi
  mkdir -p "$dest"
  ln -sf "$src_pem" "$dest/localhost.pem"
  ln -sf "$src_key" "$dest/localhost-key.pem"
  echo "[dev] linked portless certs -> ~/.simulacrum/certs" >&2
}

ensure_combined_ca_bundle() {
  local dest="$HOME/.simulacrum/certs/ca-bundle.pem"
  local portless_ca="$HOME/.portless/ca.pem"
  [ -f "$portless_ca" ] || return 1
  if ! openssl x509 -in "$portless_ca" -noout 2>/dev/null; then
    echo "[dev] $portless_ca is not a valid X.509 cert; skipping bundle" >&2
    return 1
  fi
  if [ ! -f "$dest" ] || [ "$portless_ca" -nt "$dest" ]; then
    local certifi_path
    certifi_path="$(mise x -- python -c 'import certifi; print(certifi.where())' 2>/dev/null)" || return 1
    { cat "$certifi_path"; printf '\n'; cat "$portless_ca"; } > "$dest"
  fi
  export REQUESTS_CA_BUNDLE="$dest"
  export SSL_CERT_FILE="$dest"
}

# Local Auth0 simulator gating: explicit allowlist of host shapes that the
# simulator can plausibly serve. Avoid substring matching "local" to keep
# real tenants like acme-local.eu.auth0.com from triggering dev-only side
# effects (cert symlinking, port killing, Site.domain rewrites).
case "${AUTH0_DOMAIN:-}" in
  localhost|localhost:*|*.localhost|*.localhost:*|*.local|*.local:*|auth0.local|auth0.localhost*)
    ensure_simulacrum_certs || true
    ensure_combined_ca_bundle || true
    ;;
esac

while [ $# -gt 0 ]; do
  case "$1" in
    -p|--port)
      shift
      port="${1:-}"
      if [ -z "$port" ]; then
        echo "missing port after -p/--port" >&2
        exit 2
      fi
      ;;
    --lan)
      use_lan="1"
      ;;
    --trust)
      do_trust="1"
      ;;
    --portless)
      use_portless="1"
      ;;
    --no-portless)
      use_portless="0"
      ;;
    --)
      shift
      break
      ;;
    *)
      echo "unknown arg: $1" >&2
      exit 2
      ;;
  esac
  shift
done

if [ -n "$port" ]; then
  export PORTLESS_APP_PORT="$port"
fi

if [ "${PORT:-}" != "" ]; then
  export PORTLESS_APP_PORT="${PORT}"
fi

if [ "${VITE_PORT:-}" = "" ]; then
  export VITE_PORT="$(mise x -- python -c "import socket; s=socket.socket(); s.bind(('127.0.0.1',0)); print(s.getsockname()[1]); s.close()")"
fi

if [ "$use_portless" = "1" ]; then
  PORTLESS=(npx --prefix src/ludamus/client portless)

  if [ "$use_lan" = "1" ]; then
    export PORTLESS_LAN=1
    if [ "$do_trust" = "1" ]; then
      sudo -E "${PORTLESS[@]}" trust
    fi
    PORTLESS=(sudo -E "${PORTLESS[@]}")
  else
    export PORTLESS_PORT=1355
    export PORTLESS_TLD=localhost
    export PORTLESS_LAN=0
    export PORTLESS_HTTPS=0
  fi

  exec "${PORTLESS[@]}" run --force --name "$(basename "$PWD")" \
    -- ./scripts/dev-portless-child
fi

export PORT="${PORT:-8000}"
exec honcho start -e /dev/null -f Procfile.dev
