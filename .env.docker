# Config example for docker deployment

# Python
DJANGO_SETTINGS_MODULE=ludamus.edges.settings

# Domains
ALLOWED_HOSTS=.domain.example.com
ROOT_DOMAIN=domain.example.com
# SESSION_COOKIE_DOMAIN=.your-domain.com

# Auth0
AUTH0_CLIENT_ID=auth0_client_id
AUTH0_CLIENT_SECRET=auth0_client_secret
AUTH0_DOMAIN=auth0_domain

# Database
DB_HOST=db
DB_NAME=ludamus
DB_PASSWORD=secret-password
DB_PORT=5432
DB_USER=ludamus
USE_POSTGRES=true

# Static files
# GIT_COMMIT_SHA should be set in the environment
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# Membership API
MEMBERSHIP_API_BASE_URL=https://membership.example.com
MEMBERSHIP_API_TOKEN=membership-secret-token

# Other
DEBUG=false
ENV=production
SECRET_KEY=docker-secret-key
SUPPORT_EMAIL="support@example.com"

# Docker Compose volume locations
POSTGRES_DATA_PATH=/home/ludamus/postgres_data
STATIC_DATA_PATH=/home/ludamus/static
MEDIA_DATA_PATH=/home/ludamus/media

# Connection credentials encryption
CREDENTIALS_ENCRYPTION_KEY=base64-encrypted-key
