import "../Builtins.pkl"
import "../Config.pkl"

@Builtins.meta {
  category = "Go"
  description = "Go meta-linter"
  project_indicators {
    new { file = "go.mod" }
  }
}
golangci_lint = new Config.Step {
  glob = "**/*.go"
  workspace_indicator = "go.mod"
  check = "cd {{workspace}} && golangci-lint run --fix=false ./..."
  fix = "cd {{workspace}} && golangci-lint run --fix ./..."
}
